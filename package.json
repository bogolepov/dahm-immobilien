		"build-emails-prod": "rimraf --glob ./netlify/functions/lib/emails/html/*.html && mjml ./netlify/functions/lib/emails/mjml/*.mjml -o ./netlify/functions/lib/emails/html && node ./netlify/functions/lib/emails/postprocess-html.mjs --prod"
	},
	"dependencies": {
