		"@astrojs/vue": "^6.0.1",
		"@netlify/functions": "^5.2.2",
		"@supabase/supabase-js": "^2.108.0",
		"astro": "^6.3.7",
		"astro-icon": "^1.1.5",
		"cookie": "^1.1.1",
